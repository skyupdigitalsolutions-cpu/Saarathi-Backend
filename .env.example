# ---- Server ----
PORT=5000

# ---- Database ----
# Local Mongo or Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/saarathi_crm

# ---- OpenAI API (classification + copilot) ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Fast/cheap model for auto-classifying every incoming lead
CLASSIFIER_MODEL=gpt-4o-mini
# Model for the in-CRM copilot. gpt-4o = best multi-step tool use.
# Switch to gpt-4o-mini if you want lower cost (still works, slightly less sharp).
COPILOT_MODEL=gpt-4o

# ---- Frontend origin (CORS) ----
CLIENT_ORIGIN=http://localhost:5173

# ---- Meta lead webhook verify token (set the same value in Meta dashboard) ----
META_VERIFY_TOKEN=saarathi_verify_123

# ---- Messaging channels: keep OFF until DLT/MSG91 registration clears ----
# Flip to true to activate. Bot can DRAFT messages even while these are false,
# it just won't SEND until the matching channel is enabled.
CHANNEL_WHATSAPP=false
CHANNEL_SMS=false
CHANNEL_EMAIL=false

# ---- MSG91 (fill in when SMS/WhatsApp go live) ----
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SKUPDS
MSG91_DLT_TE_ID=
# MSG91 WhatsApp: the client's integrated WhatsApp sender number (digits only, with country code, e.g. 919845012345)
MSG91_WA_NUMBER=

# ---- WhatsApp (chat threads, templates, inbound webhook) ----
# Flip CHANNEL_WHATSAPP=true above to activate the WhatsApp tab.
# Provider is MSG91 here. Sends use MSG91_AUTH_KEY + MSG91_WA_NUMBER above.
# (Set WHATSAPP_PROVIDER=meta to use Meta Cloud API instead, then fill the WHATSAPP_* vars.)
WHATSAPP_PROVIDER=msg91
WHATSAPP_API_BASE=https://graph.facebook.com/v21.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_DEFAULT_LANG=en
WHATSAPP_VERIFY_TOKEN=saarathi_wa_verify_123

# ---- Daily report → Telegram (no DLT needed) ----
# 1. Message @BotFather on Telegram -> /newbot -> copy the token here.
# 2. Add the bot to your group (or DM it), then get the chat id
#    (e.g. message the bot, open https://api.telegram.org/bot<TOKEN>/getUpdates, copy chat.id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Auto-send the report every evening WHILE the server is running (true/false):
REPORT_AUTOSEND=false
REPORT_HOUR=20
REPORT_MINUTE=0
